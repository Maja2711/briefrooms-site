{
  "method_version": "2.0.0",
  "name": "BriefRooms Weekly Market Direction Model",
  "model_status": "paper_trading_rule_based_not_investment_advice",
  "language_note": "Version 2.0.0 replaces the unvalidated prototype. Forecasts are frozen before the week, neutral signals never receive entries, volatility is an actual model input, entry and exit timestamps are reconstructed from fixed target windows, and closed history is not rewritten.",
  "timezone": "Europe/Warsaw",
  "market_window": {
    "forecast_day": "Sunday",
    "entry_target": "Monday 08:00 Europe/Warsaw",
    "entry_latest": "Monday 10:00 Europe/Warsaw",
    "planned_exit": "Friday 22:00 Europe/Warsaw",
    "entry_execution": "first available 5-minute bar at or after the fixed target",
    "scheduled_exit_execution": "first available 5-minute bar at or after the fixed target",
    "same_bar_sl_tp_rule": "stop_loss_first_conservative"
  },
  "instruments": [
    {
      "id": "eurusd",
      "label_pl": "EUR/USD",
      "label_en": "EUR/USD",
      "symbol": "EURUSD=X",
      "asset_class": "fx",
      "result_unit": "pips",
      "pip_size": 0.0001,
      "notional_eur": 10000,
      "result_currency": "USD"
    },
    {
      "id": "sp500_futures",
      "label_pl": "S&P 500 futures",
      "label_en": "S&P 500 futures",
      "symbol": "ES=F",
      "asset_class": "equity_index_futures",
      "result_unit": "points",
      "point_size": 1.0,
      "notional_usd": 10000,
      "result_currency": "USD"
    },
    {
      "id": "btcusd",
      "label_pl": "BTC/USD",
      "label_en": "BTC/USD",
      "symbol": "BTC-USD",
      "asset_class": "crypto",
      "result_unit": "percent",
      "point_size": 1.0,
      "notional_usd": 10000,
      "result_currency": "USD"
    }
  ],
  "signal_model": {
    "minimum_daily_closes": 260,
    "trend_components": {
      "ema20_vs_ema50_normalized_by_atr14": 20,
      "last_close_vs_ema20_normalized_by_atr14": 10
    },
    "momentum_components": {
      "five_day_return_normalized_by_realized_volatility": 15,
      "twenty_day_return_normalized_by_realized_volatility": 20
    },
    "breakout_component": {
      "position_in_prior_55_day_range": 15
    },
    "volatility_regime": {
      "input": "annualized 20-day volatility divided by annualized 60-day volatility",
      "rule": "high volatility scales down the directional score instead of adding directional points"
    },
    "agreement_rule": "at least two of trend, momentum and breakout groups must agree with the direction",
    "manual_override_rule": "manual macro overrides are ignored unless timestamped before forecast creation and explicitly marked valid for the forecast week",
    "confidence_definition": "heuristic signal strength only; never a probability of success"
  },
  "manual_overrides": {
    "eurusd": {
      "macro_bias": 0,
      "event_risk_penalty": 0,
      "valid_for_week": "",
      "set_at": null
    },
    "sp500_futures": {
      "macro_bias": 0,
      "event_risk_penalty": 0,
      "valid_for_week": "",
      "set_at": null
    },
    "btcusd": {
      "macro_bias": 0,
      "event_risk_penalty": 0,
      "valid_for_week": "",
      "set_at": null
    }
  },
  "decision_rules": {
    "neutral_label": "neutral/no-trade",
    "entry_thresholds": {
      "eurusd": {
        "long": 35,
        "short": -35
      },
      "sp500_futures": {
        "long": 35,
        "short": -42
      },
      "btcusd": {
        "long": 45,
        "short": -45
      }
    }
  },
  "risk_model": {
    "source": "ATR14 multiplied by square root of five and frozen at forecast time",
    "stop_atr_week_multiplier": 0.55,
    "take_atr_week_multiplier": 0.9,
    "same_bar_rule": "stop loss first when both SL and TP are inside one 5-minute bar",
    "reentry_after_stop_loss": false,
    "unit_limits": {
      "eurusd": {
        "min_stop_units": 35,
        "max_stop_units": 95,
        "min_take_units": 55,
        "max_take_units": 150
      },
      "sp500_futures": {
        "min_stop_units": 55,
        "max_stop_units": 170,
        "min_take_units": 85,
        "max_take_units": 260
      },
      "btcusd": {
        "min_stop_units": 3.5,
        "max_stop_units": 6.0,
        "min_take_units": 5.5,
        "max_take_units": 9.5
      }
    }
  },
  "validation": {
    "status": "requires_out_of_sample_and_paper_trading_evidence",
    "transaction_cost_assumptions": {
      "eurusd_round_trip_pips": 1.5,
      "sp500_futures_round_trip_points": 1.0,
      "btcusd_round_trip_percent": 0.2
    },
    "minimum_requirements_before_claiming_validation": {
      "aggregate_closed_trades": 150,
      "minimum_trades_per_instrument": 40,
      "positive_net_expectancy_after_costs": true,
      "profit_factor_above": 1.05,
      "maximum_drawdown_below_percent": 20
    }
  },
  "publishing_rules": {
    "forecast_must_include_method_version": true,
    "forecast_must_include_hash": true,
    "do_not_edit_closed_history": true,
    "do_not_open_neutral_scenarios": true,
    "do_not_use_current_price_as_late_entry_or_late_close_fallback": true,
    "show_educational_disclaimer": true,
    "use_model_scenario_language_only": true,
    "avoid_order_instruction_language": true
  }
}
