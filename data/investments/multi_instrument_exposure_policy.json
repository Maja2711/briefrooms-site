{
  "policy_version": "5.0.0",
  "name": "BriefRooms governed multi-instrument weekly paper exposure",
  "status": "experimental_paper_trading_only",
  "enabled": true,
  "mandatory_monday_position": false,
  "monday_open_not_before_local": "08:00",
  "scheduled_friday_close_local": "22:00",
  "reentry_after_any_close": false,
  "minimum_minutes_after_exit": 5,
  "max_simultaneous_positions_per_instrument": 1,
  "instruments": [
    {"instrument_id": "eurusd", "enabled": true, "round_trip_cost": 1.5, "cost_unit": "pips", "default_tie_direction": "long"},
    {"instrument_id": "sp500_futures", "enabled": true, "round_trip_cost": 1.0, "cost_unit": "points", "default_tie_direction": "long"},
    {"instrument_id": "btcusd", "enabled": true, "round_trip_cost": 0.2, "cost_unit": "percent", "default_tie_direction": "long"}
  ],
  "strategy_tournament": {
    "enabled": true,
    "candidate_methods": ["base_v2", "inverse_v2", "weekly_trend", "daily_weekly_blend", "ema_mean_reversion"],
    "rolling_closed_legs": 120,
    "minimum_observations_before_performance_weight": 6,
    "prior_observations": 5,
    "performance_weight": 18.0,
    "exploration_bonus": 2.5,
    "maximum_learning_adjustment": 18.0,
    "rule": "Candidate methods are evaluated separately using only earlier closed paper legs. A losing direction never proves that its inverse is profitable."
  },
  "weekly_candle_model": {
    "enabled": true,
    "minimum_weekly_bars": 40,
    "ema_fast": 10,
    "ema_slow": 30,
    "momentum_fast_weeks": 4,
    "momentum_slow_weeks": 13,
    "breakout_lookback_weeks": 26,
    "weights": {"trend": 35, "momentum_fast": 25, "momentum_slow": 20, "breakout": 15, "last_candle": 5}
  },
  "no_trade": {
    "enabled": true,
    "minimum_directional_raw_score": 35.0,
    "minimum_directional_utility": 6.0,
    "conflict_no_trade_below_raw_score": 45.0,
    "block_on_data_quality_failure": true,
    "rule": "NO_TRADE is a first-class decision whenever evidence is weak, conflicting or unavailable."
  },
  "execution_integrity": {
    "entry_decision_must_precede_entry": true,
    "first_completed_5m_bar_after_decision": true,
    "no_historical_backfill": true,
    "rule": "Every entry timestamp must be on or after the immutable decision timestamp."
  },
  "reentry_policy": {
    "after_stop_loss": true,
    "after_take_profit": true,
    "after_strategy_switch": true,
    "after_thesis_invalidation": false,
    "after_material_event_exit": false,
    "block_scope": "until_scheduled_week_end"
  },
  "daily_analysis": {
    "enabled": true,
    "review_after_local_hour": 23,
    "write_on_entry_or_reentry": true,
    "max_saved_reviews_per_instrument": 30,
    "show_latest_review_on_public_page": true
  },
  "learning_guardrails": {
    "use_only_closed_earlier_paper_legs": true,
    "no_future_data": true,
    "no_rewrite_of_closed_history": true,
    "no_guaranteed_profit_claims": true,
    "do_not_increase_notional_after_losses": true,
    "real_broker_orders": false,
    "paper_trading_only": true
  }
}
